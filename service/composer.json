{
    "name": "newsolari/event-planning-service",
    "description": "Standalone service for Event Planning module",
    "type": "project",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "newsolari/core": "@dev",
        "newsolari/event-planning": "*"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../backend",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../../webos/packages/core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../budgets/backend",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../people/backend",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../files/backend",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../events/backend",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../ai-service/backend",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.3",
        "newsolari/budgets": "@dev",
        "newsolari/people": "@dev",
        "newsolari/files": "@dev",
        "newsolari/events": "@dev"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
