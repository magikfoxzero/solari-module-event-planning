{
    "name": "newsolari/event-planning",
    "description": "Event Planning module for SolariWebOS",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "newsolari/core": "^1.0 || @dev"
    },
    "autoload": {
        "psr-4": {
            "NewSolari\\EventPlanning\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NewSolari\\EventPlanning\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
